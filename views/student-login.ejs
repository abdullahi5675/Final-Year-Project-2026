<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NELFUND Refund Portal — Student Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', Arial, sans-serif;
            background-color: #f5f7f5;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 30px 20px;
        }

        /* ── Dual Logo Header ── */
        .logo-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            margin-bottom: 28px;
            background: white;
            border: 2px solid #28a745;
            border-radius: 12px;
            padding: 18px 32px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 2px 10px rgba(40,167,69,0.10);
        }

        .logo-header img {
            height: 64px;
            width: auto;
            object-fit: contain;
            flex-shrink: 0;
        }

        .logo-header-text {
            text-align: center;
            flex: 1;
        }

        .logo-header-text .institution {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: #555;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .logo-header-text .portal-name {
            font-size: 17px;
            font-weight: 700;
            color: #28a745;
            line-height: 1.2;
        }

        /* ── Login Card ── */
        .login-card {
            background: white;
            border: 2px solid #28a745;
            border-radius: 12px;
            padding: 36px 32px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 4px 20px rgba(40,167,69,0.10);
        }

        .card-title {
            font-size: 20px;
            font-weight: 700;
            color: #1a5c2a;
            margin-bottom: 6px;
        }

        .card-subtitle {
            font-size: 13px;
            color: #777;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e0ede3;
        }

        .form-group { margin-bottom: 22px; }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #1a5c2a;
            margin-bottom: 8px;
            letter-spacing: 0.2px;
        }

        input[type="text"] {
            width: 100%;
            padding: 13px 14px;
            border: 1.5px solid #c3dbc9;
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            color: #222;
            background: #fafff9;
            transition: border-color 0.25s, box-shadow 0.25s;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #28a745;
            box-shadow: 0 0 0 3px rgba(40,167,69,0.12);
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0.4px;
            cursor: pointer;
            transition: background-color 0.25s, transform 0.1s;
            margin-top: 4px;
        }

        .btn-submit:hover { background-color: #218838; }
        .btn-submit:active { transform: scale(0.99); }

        .error {
            background-color: #fdf2f3;
            color: #8b1a27;
            padding: 12px 14px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 13px;
            border: 1px solid #f5c6cb;
        }

        .footer-note {
            font-size: 12px;
            color: #888;
            text-align: center;
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid #e0ede3;
        }

        .staff-link {
            text-align: center;
            margin-top: 14px;
            font-size: 13px;
        }

        .staff-link a {
            color: #28a745;
            text-decoration: none;
            font-weight: 500;
        }

        .staff-link a:hover { text-decoration: underline; }

        @media (max-width: 480px) {
            body {
                padding: 20px 12px;
            }
            .logo-header {
                flex-direction: column;
                gap: 12px;
                padding: 16px 20px;
                text-align: center;
            }
            .logo-header img {
                height: 48px;
            }
            .login-card {
                padding: 24px 20px;
            }
            .card-title {
                font-size: 18px;
            }
            .card-subtitle {
                font-size: 12px;
                margin-bottom: 20px;
                padding-bottom: 16px;
            }
        }
    </style>
</head>
<body>

    <!-- Dual Logo Header -->
    <div class="logo-header">
        <img src="/FUTBBBBBBB.png" alt="FUTB Logo">
        <div class="logo-header-text">
            <div class="institution">Federal University of Technology, Babura</div>
            <div class="portal-name">NELFUND Refund Portal</div>
        </div>
        <img src="/Nelfund .webp" alt="NELFUND Logo">
    </div>

    <!-- Login Card -->
    <div class="login-card">
        <div class="card-title">Student Login</div>
        <div class="card-subtitle">Enter your registration number to access your refund status</div>

        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <form method="POST" action="/login">
            <div class="form-group">
                <label for="reg_number">Registration Number</label>
                <input type="text" id="reg_number" name="reg_number" required
                    placeholder="e.g. FUT/CST/20/00001" autofocus>
            </div>
            <button type="submit" class="btn-submit">Login &rarr;</button>
        </form>

        <div class="footer-note">
            Only students on the NELFUND approved list can access this portal.
        </div>
        <div class="staff-link">
            <a href="/staff/login">Staff Login &rarr;</a>
        </div>
    </div>

</body>
</html>
